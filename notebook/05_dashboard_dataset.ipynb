import os
import pandas as pd
from src.workload_metrics import provider_workload, department_workload
from src.continuity_metrics import continuity_scores, high_utilizers

# Robust base path resolution
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
data_path = lambda f: os.path.join(BASE_DIR, '..', 'data', f)

# Load data with error handling
try:
    df = pd.read_csv(data_path('patient_encounters_clean.csv'))
except FileNotFoundError:
    raise FileNotFoundError(f"CSV not found at: {data_path('patient_encounters_clean.csv')}")

# Compute metrics
prov_workload = provider_workload(df)
dept_workload = department_workload(df)
cont_df = continuity_scores(df)
high_util_df = high_utilizers(df)

# Validate outputs
for name, result in [
    ('provider_workload', prov_workload),
    ('department_workload', dept_workload),
    ('continuity_scores', cont_df),
    ('high_utilizers', high_util_df),
]:
    assert isinstance(result, pd.DataFrame), f"{name}() returned unexpected result: {type(result)}"

# Merge continuity with patient demographics
# drop_duplicates on patient_id to avoid duplicate rows in merge
patient_demo = df[['patient_id', 'gender', 'age', 'race']].drop_duplicates(subset=['patient_id'])
cont_with_demo = cont_df.merge(patient_demo, on='patient_id', how='left')

# Export to CSV
cont_with_demo.to_csv(data_path('dashboard_continuity.csv'), index=False)
prov_workload.to_csv(data_path('dashboard_provider_workload.csv'), index=False)
dept_workload.to_csv(data_path('dashboard_department_workload.csv'), index=False)
high_util_df.to_csv(data_path('dashboard_high_utilizers.csv'), index=False)

print("All dashboard files exported successfully.")
